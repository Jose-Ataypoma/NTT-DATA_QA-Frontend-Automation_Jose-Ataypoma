{
  "name": "sauce-demo-tests",
  "version": "1.0.0",
  "description": "Suite de pruebas automatizadas con Playwright + Cucumber",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js",
    "test:allure": "cucumber-js -p allure",
    "allure:generate": "npx allure generate allure-results --output allure-report",
    "allure:open": "npx allure open allure-report",
    "test:report": "cucumber-js --format json:reports/cucumber.json && node reports/generate-report.js",
    "test:login": "cucumber-js --tags '@login'",
    "test:carrito": "cucumber-js --tags '@carrito'",
    "test:compra": "cucumber-js --tags '@compra'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jose-Ataypoma/sauce-demo-tests.git"
  },
  "keywords": [],
  "author": "Jose",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Jose-Ataypoma/sauce-demo-tests/issues"
  },
  "homepage": "https://github.com/Jose-Ataypoma/sauce-demo-tests#readme",
  "devDependencies": {
    "@cucumber/cucumber": "^10.0.0",
    "@types/node": "^25.9.3",
    "allure": "^3.12.0",
    "allure-cucumberjs": "^3.10.0",
    "playwright": "^1.61.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.4.0"
  }

}
